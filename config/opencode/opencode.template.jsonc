{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "skills": {
    "paths": [
      "__HOME__/.opencode/skills/agents",
      "__HOME__/.opencode/skills/codex"
    ]
  },
  "agent": {
    "codex-primary": {
      "description": "Primary coding agent for full-stack implementation",
      "model": "openai/gpt-5.3-codex"
    },
    "architect": {
      "description": "Architecture and planning agent",
      "model": "anthropic/claude-opus-4-1"
    },
    "fast": {
      "description": "Fast edits and quick lookup agent",
      "model": "anthropic/claude-sonnet-4-5"
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "__HOME__"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 10000
    }
  }
}
